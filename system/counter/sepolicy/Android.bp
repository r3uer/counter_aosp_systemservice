cc_defaults {
    name: "counter_sepolicy_licenses",
    licenses: [
        "Android-Apache-2.0",
    ],
}

prebuilt_etc {
    name: "counter_service_contexts",
    src: "counter_service_contexts",
    sub_dir: "selinux",
    filename_from_src: true,
}

prebuilt_etc {
    name: "counter_service_property_contexts",
    src: "counter_service_property_contexts",
    sub_dir: "selinux",
    filename_from_src: true,
}
