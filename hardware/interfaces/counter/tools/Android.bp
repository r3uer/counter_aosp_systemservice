cc_binary {
    name: "hal_counter_client",
    srcs: [
        "hal_counter_client.cpp",
    ],
    shared_libs: [
        "libbase",
        "libbinder_ndk",
        "android.hardware.counter-aidl-ndk",
        "libutils",
    ],
    cflags: [
        "-Wall",
        "-Wextra",
        "-Werror",
    ],
}
